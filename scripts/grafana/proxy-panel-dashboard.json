  "liveNow": false,
  "panels": [
    {
      "type": "stat",
      "title": "节点在线数",
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "gridPos": {"h": 4, "w": 6, "x": 0, "y": 0},
      "targets": [
        {"expr": "sum(proxy_panel_node_health == 1)", "legendFormat": "在线", "refId": "A"}
      ],
      "options": {"reduceOptions": {"values": false, "calcs": ["last"], "fields": ""}, "colorMode": "value"},
      "fieldConfig": {"defaults": {"color": {"mode": "thresholds"}, "thresholds": {"mode": "absolute", "steps": [{"color": "red", "value": null}, {"color": "green", "value": 1}]}}}
    },
    {
      "type": "stat",
      "title": "订阅请求率 (1m)",
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "gridPos": {"h": 4, "w": 6, "x": 6, "y": 0},
      "targets": [
        {"expr": "sum(rate(proxy_panel_subscription_requests_total[1m]))", "legendFormat": "req/s", "refId": "A"}
      ],
      "fieldConfig": {"defaults": {"unit": "reqps"}}
    },
    {
      "type": "stat",
      "title": "内核同步 P95 (5m)",
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "gridPos": {"h": 4, "w": 6, "x": 12, "y": 0},
      "targets": [
        {"expr": "histogram_quantile(0.95, sum by (le, kernel) (rate(proxy_panel_kernel_sync_duration_seconds_bucket[5m])))", "legendFormat": "{{kernel}}", "refId": "A"}
      ],
      "fieldConfig": {"defaults": {"unit": "s"}}
    },
    {
      "type": "stat",
      "title": "同步失败 (5m)",
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "gridPos": {"h": 4, "w": 6, "x": 18, "y": 0},
      "targets": [
        {"expr": "sum(increase(proxy_panel_kernel_sync_failures_total[5m]))", "legendFormat": "失败", "refId": "A"}
      ],
      "fieldConfig": {"defaults": {"color": {"mode": "thresholds"}, "thresholds": {"mode": "absolute", "steps": [{"color": "green", "value": null}, {"color": "red", "value": 1}]}}}
    },
    {
      "type": "timeseries",
      "title": "订阅请求 (按客户端)",
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "gridPos": {"h": 8, "w": 12, "x": 0, "y": 4},
      "targets": [
        {"expr": "sum by (client) (rate(proxy_panel_subscription_requests_total[1m]))", "legendFormat": "{{client}}", "refId": "A"}
      ],
      "fieldConfig": {"defaults": {"unit": "reqps"}}
    },
    {
      "type": "timeseries",
      "title": "订阅请求状态分布",
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "gridPos": {"h": 8, "w": 12, "x": 12, "y": 4},
      "targets": [
        {"expr": "sum by (status) (rate(proxy_panel_subscription_requests_total[1m]))", "legendFormat": "{{status}}", "refId": "A"}
      ],
      "fieldConfig": {"defaults": {"unit": "reqps"}}
    },
    {
      "type": "timeseries",
      "title": "内核同步耗时 (P95)",
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "gridPos": {"h": 8, "w": 12, "x": 0, "y": 12},
      "targets": [
        {"expr": "histogram_quantile(0.95, sum by (le, kernel) (rate(proxy_panel_kernel_sync_duration_seconds_bucket[5m])))", "legendFormat": "{{kernel}} p95", "refId": "A"},
        {"expr": "histogram_quantile(0.50, sum by (le, kernel) (rate(proxy_panel_kernel_sync_duration_seconds_bucket[5m])))", "legendFormat": "{{kernel}} p50", "refId": "B"}
      ],
      "fieldConfig": {"defaults": {"unit": "s"}}
    },
    {
      "type": "timeseries",
      "title": "内核同步失败率",
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "gridPos": {"h": 8, "w": 12, "x": 12, "y": 12},
      "targets": [
        {"expr": "sum by (kernel, reason) (rate(proxy_panel_kernel_sync_failures_total[5m]))", "legendFormat": "{{kernel}} / {{reason}}", "refId": "A"}
      ]
    },
    {
      "type": "timeseries",
      "title": "节点流量速率 (上下行)",
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "gridPos": {"h": 8, "w": 12, "x": 0, "y": 20},
      "targets": [
        {"expr": "sum by (node, direction) (rate(proxy_panel_node_traffic_bytes_total[1m]))", "legendFormat": "node {{node}} {{direction}}", "refId": "A"}
      ],
      "fieldConfig": {"defaults": {"unit": "Bps"}}
    },
    {
      "type": "timeseries",
      "title": "节点健康",
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "gridPos": {"h": 8, "w": 12, "x": 12, "y": 20},
      "targets": [
        {"expr": "proxy_panel_node_health", "legendFormat": "{{node}} ({{protocol}})", "refId": "A"}
      ],
      "fieldConfig": {"defaults": {"min": 0, "max": 1}}
    },
    {
      "type": "timeseries",
      "title": "面板全局流量速率",
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "gridPos": {"h": 8, "w": 12, "x": 0, "y": 28},
      "targets": [
        {"expr": "sum by (direction) (rate(proxy_panel_server_traffic_bytes_total[1m]))", "legendFormat": "{{direction}}", "refId": "A"}
      ],
      "fieldConfig": {"defaults": {"unit": "Bps"}}
    },
    {
      "type": "timeseries",
      "title": "告警发送速率",
      "datasource": {"type": "prometheus", "uid": "prometheus"},
      "gridPos": {"h": 8, "w": 12, "x": 12, "y": 28},
      "targets": [
        {"expr": "sum by (type) (rate(proxy_panel_alerts_sent_total[5m]))", "legendFormat": "{{type}}", "refId": "A"}
      ]
    }
